# Ollama backend URL
OLLAMA_URL=http://localhost:11434

# Straddle listener — use Tailscale IP (100.x.x.x) or 127.0.0.1; never 0.0.0.0
STRADDLE_HOST=127.0.0.1
STRADDLE_PORT=11435

# API key for X-API-Key header auth (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
STRADDLE_API_KEY=

# Path to prompts directory (default: ./prompts)
PROMPTS_DIR=

# Default model when none specified in request (e.g. qwen2.5-coder:7b)
DEFAULT_MODEL=

# Context window size (default: 8192)
NUM_CTX=8192

# Keep model loaded between requests: -1 = forever, 0 = unload immediately
KEEP_ALIVE=-1

# Telegram bot (optional — only needed for telegram_gateway.py)
TELEGRAM_BOT_TOKEN=
